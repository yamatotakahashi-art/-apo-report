# ===== Auth.js（NextAuth v5） =====
# 生成: openssl rand -base64 33
AUTH_SECRET=

# Google OAuth クライアント（Google Cloud Console → 認証情報 → OAuth クライアントID）
# 承認済みリダイレクトURI: https://<本番ドメイン>/api/auth/callback/google
#                          http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# 本番URL（Vercelでは自動。ローカルは未設定でOK）
# AUTH_URL=https://your-app.vercel.app

# ===== アクセス制御 =====
# ログインを許可するメールドメイン（カンマ区切り）。例: example.co.jp
# 空にすると全Googleアカウントを許可してしまうので、必ず社内ドメインを設定すること。
ALLOWED_EMAIL_DOMAINS=

# 初回ログイン時に「正社員（テンプレ編集可）」として登録するメール（カンマ区切り）
# 登録後の昇格/降格は DB の users.role を直接更新する運用。
ADMIN_EMAILS=

# ===== Neon Postgres =====
# Neon ダッシュボードの「Pooled connection」文字列（?sslmode=require 付き）
DATABASE_URL=

# ===== 任意: Slack送信用GAS設定をサーバ集中管理する場合 =====
# 設定すると全ユーザーが各自で入力せずに使える（未設定なら従来どおり各ブラウザで入力）。
# GAS_URL=https://script.google.com/macros/s/xxxx/exec
# SLACK_WEBHOOKS=[{"key":"progress","label":"進捗・アポ報告CH"},{"key":"bug","label":"バグ報告CH"},{"key":"idea","label":"機能アイデアCH"}]
